# This is an example of your .env file format, which pnpm db:setup will create.
# Note: this must be .env, not .env.local, without further configuration changes.
POSTGRES_URL=postgresql://<user>:<password>@<host>:5432/facesmash_devportal?sslmode=require
STRIPE_SECRET_KEY=sk_live_***
STRIPE_WEBHOOK_SECRET=whsec_***
BASE_URL=https://developers.facesmash.app
AUTH_SECRET=<64-char-hex>

# Unkey — API key management
UNKEY_ROOT_KEY=unkey_***
UNKEY_API_ID=api_***

# Resend — email service
RESEND_API_KEY=re_***
RESEND_DOMAIN_ID=
ROOT_SPF_VALUE="v=spf1 include:amazonses.com include:spf.protection.outlook.com -all"
DMARC_VALUE=
DMARC_REPORT_EMAIL=dmarc@example.com

GODADDY_API_KEY=
GODADDY_API_SECRET=
GODADDY_DOMAIN=everjust.co
DNS_TTL=600

# FaceSmash Hono API (face data backend)
FACESMASH_API_URL=https://api.facesmash.app
FACESMASH_INTERNAL_API_KEY=421afe5c20e7ad857664dd7bb4e05662

# FaceCard — dev portal's own app_id for scoping face profiles
DEVPORTAL_APP_ID=devportal
